# Секрет для авторизации запросов от Next.js (должен совпадать с BROWSER_WORKER_SECRET в Next.js-сервисе).
BROWSER_WORKER_SECRET=change_me_to_a_long_random_string
# Порт (Railway выставляет автоматически). Локально:
PORT=8090
# Сколько браузерных контекстов одновременно (Chromium ~300–500 МБ на контекст — не завышать).
BROWSER_CONCURRENCY=2
# Показывать окно браузера (только локальная отладка; в Docker/Railway всегда headless).
BROWSER_HEADFUL=0
