generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?                          // null у пользователей, вошедших через Google
  googleId      String?   @unique                // Google sub (OAuth)
  image         String?                          // аватар из Google
  emailVerified DateTime?                         // когда почта подтверждена кодом / через Google
  plan          String    @default("free")       // тариф (задел под биллинг: free / pro / …)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  InstagramAccount[]
  triggers  TriggerRule[]
  templates Template[]
  sections  Section[]
  proxies   Proxy[]
  settings  UserSettings?
}

// Лок для защиты от параллельного запуска фоновых задач (напр. поллинга).
// Аренда с истечением: если процесс упал — лок сам «протухнет» после lockedUntil.
model AppLock {
  key         String   @id
  lockedUntil DateTime @default(now())
}

// Ожидающая подтверждения регистрация: юзер создаётся только после ввода кода с почты.
model EmailVerification {
  email     String   @id                 // одна активная заявка на email
  codeHash  String                        // bcrypt-хэш 6-значного кода
  password  String                        // bcrypt-хэш выбранного пароля
  name      String?
  attempts  Int      @default(0)          // неверные попытки ввода кода
  expiresAt DateTime                       // срок действия кода
  sentAt    DateTime @default(now())       // для троттлинга повторной отправки
}

// Настройки пользователя
model UserSettings {
  userId           String  @id
  accountsPerProxy Int     @default(3)      // сколько аккаунтов авто-вешать на один пуловый прокси
  allowNoProxy     Boolean @default(false)  // разрешить работу аккаунтов без прокси (риск бана)
  allowNoDrafts    Boolean @default(false)  // разрешить основным парсить самим, когда нет черновых

  // Переход на браузерную автоматизацию («эмуль»). См. plan.md §3/§5/§7.6.
  parsingSource  String  @default("api")     // "api" | "drafts" | "drafts_then_api" — источник парсинга
  actionEngine   String  @default("browser") // "browser" | "legacy" — движок входа/действий (browser = Playwright-воркер)
  browserHeadful Boolean @default(false)      // отладка: показывать окно браузера (только локально)

  // Распределение действий основной/черновой (защита основного от бана).
  // true → «палевное» действие выполняет ЧЕРНОВОЙ (если есть живой), сохраняя основной.
  // Директ, ответ в комментах и «подписка в ответ» ВСЕГДА выполняет основной (иначе теряется смысл).
  likeByDraft  Boolean @default(false)  // лайки постов цели выполняет черновой
  storyByDraft Boolean @default(false)  // просмотр/лайк сторис выполняет черновой

  user User @relation(fields: [userId], references: [id])
}

// Прокси: пуловые (авто-привязка) и индивидуальные (вводятся вручную при создании аккаунта)
model Proxy {
  id        String   @id @default(cuid())
  userId    String
  url       String
  kind      String   @default("pool")   // pool | individual
  label     String?
  createdAt DateTime @default(now())

  // Здоровье прокси — результат последней проверки («Проверить все прокси»).
  // Хранится, чтобы подбор при входе сразу пропускал мёртвые/датацентр без live-перепроверки
  // всего пула на каждом логине (иначе таймаут воркера → тихий фолбэк на плохой прокси).
  status        String    @default("unknown")  // unknown | alive | dead
  lastCheckedAt DateTime?
  ip            String?
  country       String?
  isp           String?
  scheme        String?                          // http | socks5 | socks4
  datacenter    Boolean?                         // флаги репутации от ipapi.is (как видит Instagram)
  vpn           Boolean?
  mobile        Boolean?
  flagged       Boolean?                         // datacenter || vpn || proxy — «Instagram забанит»
  igBlocked     Boolean?                         // Instagram при входе вернул blacklist/UserInvalidCredentials
                                                 // — этот IP реально выжжен на стороне IG (сильнее ipapi.is);
                                                 // подбор такой прокси избегает.

  user     User               @relation(fields: [userId], references: [id])
  accounts InstagramAccount[]

  @@index([userId])
}

// Пользовательские папки для аккаунтов: раздел → подраздел (двухуровневая иерархия).
// Напр. «Польша» → «Краков». Свободные названия, без справочника.
model Section {
  id        String   @id @default(cuid())
  userId    String
  parentId  String?
  name      String
  createdAt DateTime @default(now())

  user     User               @relation(fields: [userId], references: [id])
  parent   Section?           @relation("SectionTree", fields: [parentId], references: [id])
  children Section[]          @relation("SectionTree")
  accounts InstagramAccount[]

  @@index([userId])
  @@index([parentId])
}

model InstagramAccount {
  id          String        @id @default(cuid())
  userId      String
  username    String
  role        AccountRole
  sessionData Json?         // LEGACY instagrapi-сессия (Python-воркер). Читаем для совместимости.
  browserState Json?        // Playwright storageState (cookies+origins) — сессия браузерного «эмуля»
  loginMethod String  @default("legacy") // "browser" | "cookies" | "legacy" — чем вошли
  emailLogin  String?       // почта аккаунта (для авточтения кода checkpoint по IMAP)
  emailPassword String?     // пароль почты (только для IMAP; наружу в API НЕ отдаём)
  proxy       String?
  status      AccountStatus @default(ACTIVE)
  lastChecked DateTime?
  errorCount  Int           @default(0)
  limits      Json?
  followers   Int?          // реальное число подписчиков (из account_info)
  followersHistory Json?    // история [{d:'YYYY-MM-DD', n}] для спарклайна прироста
  sectionId   String?       // раздел/подраздел (папка пользователя)
  proxyId     String?       // ссылка на прокси (пуловый/индивидуальный); строковый proxy оставлен для воркеров
  createdAt   DateTime      @default(now())  // когда аккаунт заведён — задел под «прогрев» (рампу дневных лимитов по возрасту)
  locale      String?       // IETF-локаль отпечатка браузера, выведена из страны прокси при входе (plan.md §349)
  timezoneId  String?       // IANA-таймзона отпечатка, та же страна прокси — держим стабильными между входом и действиями

  user                User           @relation(fields: [userId], references: [id])
  section             Section?       @relation(fields: [sectionId], references: [id])
  proxyRef            Proxy?         @relation(fields: [proxyId], references: [id])
  triggersAsResponder TriggerRule[]  @relation("ResponderRules")
  triggersAsHelper    TriggerRule[]  @relation("HelperRules")
  snapshots           Snapshot[]
  events              Event[]
  logs                Log[]

  @@unique([userId, username])
}

enum AccountRole {
  RESPONDER
  HELPER
  BOTH
}

enum AccountStatus {
  ACTIVE
  PAUSED
  BLOCKED
  CHALLENGE
}

model Snapshot {
  id        String       @id @default(cuid())
  accountId String
  type      SnapshotType
  data      Json
  createdAt DateTime     @default(now())

  account InstagramAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, type, createdAt])
}

enum SnapshotType {
  FOLLOWERS
  LIKES
  COMMENTS
  STORY
}

model Event {
  id        String    @id @default(cuid())
  accountId String
  type      EventType
  payload   Json
  processed Boolean   @default(false)
  createdAt DateTime  @default(now())

  account InstagramAccount @relation(fields: [accountId], references: [id])
  logs    Log[]
}

enum EventType {
  NEW_FOLLOWER
  NEW_COMMENT
  NEW_LIKE
  NEW_DIRECT_MESSAGE
  STORY_MENTION
}

model TriggerRule {
  id          String    @id @default(cuid())
  userId      String
  responderId String
  helperId    String?
  name        String
  triggerType EventType
  conditions  Json
  actions     Json
  isActive    Boolean   @default(true)
  fireCount   Int       @default(0)
  stats       Json?     // счётчики по действиям: {dm,like,follow,story,comment}
  priority    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User              @relation(fields: [userId], references: [id])
  responder InstagramAccount  @relation("ResponderRules", fields: [responderId], references: [id])
  helper    InstagramAccount? @relation("HelperRules", fields: [helperId], references: [id])
}

model Template {
  id         String   @id @default(cuid())
  userId     String
  name       String
  content    String
  category   String?
  usageCount Int      @default(0)

  user User @relation(fields: [userId], references: [id])
}

model Log {
  id        String   @id @default(cuid())
  accountId String
  eventId   String?
  level     LogLevel
  message   String
  details   Json?
  createdAt DateTime @default(now())

  account InstagramAccount @relation(fields: [accountId], references: [id])
  event   Event?           @relation(fields: [eventId], references: [id])

  @@index([createdAt])
  @@index([accountId, createdAt])
}

enum LogLevel {
  INFO
  WARN
  ERROR
  SUCCESS
}
