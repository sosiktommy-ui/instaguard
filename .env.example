# Database (PostgreSQL)
DATABASE_URL="postgresql://user:pass@localhost:5432/instaguard"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# JWT Auth
JWT_SECRET="super-secret-jwt-key-min-32-chars-change-in-prod"
JWT_EXPIRES_IN="7d"

# Encryption key for Instagram session data (exactly 32 chars)
ENCRYPTION_KEY="change-me-32-chars-encryption-key!!"

# Python instagrapi worker (LEGACY — используется, только если браузерный воркер не задан)
PYTHON_WORKER_URL="http://localhost:8001"
PYTHON_WORKER_SECRET="worker-secret-key"

# Браузерный воркер (эмуль, Playwright) — вход и действия Instagram через реальный браузер.
# См. plan.md §4 и workers/browser/README.md. Если BROWSER_WORKER_URL НЕ задан — движок
# остаётся legacy (instagrapi), приложение продолжает работать.
BROWSER_WORKER_URL=""
BROWSER_WORKER_SECRET="browser-worker-secret-change-me"
# BROWSER_WORKER_TIMEOUT_MS="120000"   # вход браузером медленнее — таймаут выше

# Скрейпер-API для парсинга подписчиков/комментариев/лайков (замена черновых аккаунтов).
# Оформить и пополнить баланс: https://hikerapi.com (оплата за запрос, ~$0.0006–0.02).
# Без этого ключа триггеры «Подписка»/«Комментарий»/«Лайк» не работают.
HIKER_API_KEY=""
# HIKER_API_BASE="https://api.hikerapi.com"   # переопределять не нужно
# HIKER_TIMEOUT_MS="30000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Railway / Production ---
# DATABASE_URL=postgresql://...
# REDIS_URL=redis://...
# PYTHON_WORKER_URL=https://your-worker.railway.app
